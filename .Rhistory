# Define the historical versions to check
versions_to_test <- c("3.3-1", "3.6-1", "3.7-0")
for (v in versions_to_test) {
# Install the specific version
remotes::install_version("survival", version = v, quiet = TRUE)
# Need to detach/unload survival if it's currently loaded
if ("package:survival" %in% search()) detach("package:survival", unload=TRUE)
library(survival)
# Run your exact test
tmp <- as.data.frame(matrix(c(1,2,6,1,3,1,3,2,4,4,6,1,5,5,7,1),byrow=TRUE,nrow=4))
names(tmp) <- c("id","tstart","tstop","status")
fit <- survfit(Surv(-tmp$tstop, -tmp$tstart, rep(1, 4)) ~ 1)
res <- summary(fit, times = c(-7, -6))
# Print the outcome
cat("Version:", v, "| Survival at time -7:", res$surv[1], "\n")
}
fit <- survfit(Surv(-tmp$tstop, -tmp$tstart, rep(1, 4)) ~ 1, entry = TRUE)
summary(fit, times = c(-7, -6))
summary(fit, times = c(-5, -6, -3, -6, -7, -6, -7))
fit <- survfit(Surv(-tmp$tstop, -tmp$tstart, rep(1, 4)) ~ 1)
summary(fit, times = c(-5, -6, -3, -6, -7, -6, -7))
tmp
fit <- survfit(Surv(-tmp$tstop, -tmp$tstart, c(1,1,0,1)) ~ 1)
summary(fit, times = c(-5, -6, -3, -6, -7, -6, -7))
fit <- survfit(Surv(-tmp$tstop, -tmp$tstart, c(1,0,1,1)) ~ 1)
summary(fit, times = c(-5, -6, -3, -6, -7, -6, -7))
# Run your exact test
tmp <- as.data.frame(matrix(c(1,2,6,1,3,1,3,2,4,4,6,1,5,5,7,1),byrow=TRUE,nrow=4))
names(tmp) <- c("id","tstart","tstop","status")
fit <- survfit(Surv(-tmp$tstop, -tmp$tstart, c(1,1,1,1)) ~ 1)
res <- summary(fit, times = c(-5, -6, -3, -6, -7, -6, -7))
res
