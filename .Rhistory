MCC.result2 <- cbind(MCC.fill[, c("time", "MCC")], MCC.result)
MCC.output <- MCC.out %>%
dplyr::left_join(
MCC.result2 %>% dplyr::select("time", "2.5%", "97.5%"),
by = "time"
) %>%
dplyr::rename(lci = "2.5%", uci = "97.5%") %>%
dplyr::mutate(
lci = zoo::na.locf(.data$lci, na.rm = FALSE),
uci = zoo::na.locf(.data$uci, na.rm = FALSE),
